@model Budget.Web.Models.PaymentForm
@{
    ViewData["Title"] = "Add Payment";
    Layout = "_Layout";
}

<h2>Add Expense</h2>

<form asp-action="Create" method="post">

    <div class="form-group mb-3">
        <label asp-for="Amount" class="form-label">Amount</label>
        <input asp-for="Amount" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <input asp-for="ExpenseId" />

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" asp-controller="Expenses" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
