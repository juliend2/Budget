@model List<Budget.Web.Models.ExpenseTemplate>;
@{
    ViewData["Title"] = "Expense Templates";
    Layout = "_Layout";
}

<div class="">
    <div class="mb-2">
        <a asp-action="Create" class="btn btn-primary btn-sm">+ Add</a>
    </div>
    <table>
        <tr>
            <th class="left-padding">Description</th>
            <th class="left-padding">Amount</th>
            <th class="left-padding">To Be Paid At</th>
            <th class="left-padding">Every (interval)</th>
            <th></th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td class='left-padding'>@item.Description</td>
                <td class='left-padding  right  gray'>@item.Amount $</td>
                <td class='left-padding'>@item.InitialToBePaidOn.ToShortDateString()</td>
                <td class='left-padding'>@(item.RepeatabilityIntervalUnit) @(item.RepeatabilityIntervalPace == null ? "None" : item.RepeatabilityIntervalPace == "D" ? "Days" : item.RepeatabilityIntervalPace == "W" ? "Weeks" : item.RepeatabilityIntervalPace == "HM" ? "Half-Monthly" : item.RepeatabilityIntervalPace == "M" ? "Months" : item.RepeatabilityIntervalPace == "Y" ? "Years" : "")</td>
                <td class='left-padding'>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this expense template?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </table>
</div>