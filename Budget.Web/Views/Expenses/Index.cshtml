@model List<List<Budget.Web.Models.BudgetLine>>;
@{
    ViewData["Title"] = "Accueil";
    Layout = "_Layout";
}

<div class="">
    <div class="mb-2">
        <a asp-action="Create" class="btn btn-primary btn-sm">+ Add</a>
    </div>
    <table>
        <tr>
            <th class="left-padding">Description</th>
            <th class="left-padding">Date</th>
            <th class="left-padding">Amount</th>
            <th class="left-padding">Remaining</th>
            <th></th>
        </tr>
        @foreach (var budgetChunk in Model)
        {
            var total = 0;
            @foreach (var item in budgetChunk) {
                <tr>
                    <td class='left-padding'>@item.Description</td>
                    <td class='left-padding'>@item.ToBePaidAt.ToShortDateString()</td>
                    <td class='left-padding  right  gray'>
                        @item.Amount $
                        <a
                            asp-route="CreatePayment"
                            asp-route-expenseId="@item.Id">Payer</a>
                    </td>
                    <td class='left-padding  right'>@item.Remaining $</td>
                    <td class='left-padding'>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this expense?')">Delete</button>
                        </form>
                    </td>
                </tr>
                total += (int)item.Remaining;
            }
            <tr class='dark'>
                <td>En date du @budgetChunk.Last().PayDate().ToShortDateString()</td>
                <td></td>
                <td></td>
                <td class='left-padding  right'>@total $</td>
                <td></td>
            </tr>
        }
    </table>
</div>
